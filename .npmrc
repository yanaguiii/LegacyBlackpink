# Proteções contra supply-chain via atualização de dependência

# Não roda install scripts (postinstall/preinstall) — principal vetor de malware
ignore-scripts=true

# Só adota versões publicadas há pelo menos 7 dias.
# Pacotes comprometidos costumam ser despublicados em horas/dias.
min-release-age=7

# Sem mensagens de "funding" poluindo o output
fund=false
